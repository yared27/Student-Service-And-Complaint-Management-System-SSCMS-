// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

model User {
  id String @id @default(uuid())

  username String @unique // university ID (login)
  name     String
  password String

  email  String?    @unique // optional now
  role   Role
  category Category?
  status UserStatus @default(ACTIVE)

  campus     String
  department String

  phone        String?
  profileImage String?

  strikeCount      Int       @default(0)
  isFlagged        Boolean   @default(false)
  isActive         Boolean   @default(true)
  lastSuspendedAt  DateTime?
  suspensionEndsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdComplaints       Complaint[]      @relation("ComplaintCreatedBy")
  assignedComplaints      Complaint[]      @relation("ComplaintAssignedTo")
  createdServiceRequests  ServiceRequest[] @relation("ServiceRequestCreatedBy")
  assignedServiceRequests ServiceRequest[] @relation("ServiceRequestAssignedTo")

  serviceManagerProfile   ServiceManager?
  complaintManagerProfile ComplaintManager?
  managedByServiceManagerId String?
  managedByComplaintManagerId String?
  managedByServiceManager ServiceManager? @relation("ServiceManagerStaff", fields: [managedByServiceManagerId], references: [id], onDelete: SetNull)
  managedByComplaintManager ComplaintManager? @relation("ComplaintManagerInvestigators", fields: [managedByComplaintManagerId], references: [id], onDelete: SetNull)

  reportsFiled    MisuseReport[] @relation("MisuseReportReporter")
  reportsAgainst  MisuseReport[] @relation("MisuseReportReportedUser")
  reportsReviewed MisuseReport[] @relation("MisuseReportReviewedBy")

  notifications Notification[]
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  importBatches ImportBatch[] @relation("ImportBatches")

  activityLogsAsActor      ActivityLog[] @relation("ActivityActor")
  activityLogsAsTargetUser ActivityLog[] @relation("ActivityTargetUser")
  materialRequestsAsRequester MaterialRequest[] @relation("MaterialRequestRequester")
  materialRequestsAsManager MaterialRequest[] @relation("MaterialRequestManager")

  @@index([role, status])
  @@index([category, role, status])
  @@index([campus, department])
}

model ServiceManager {
  id String @id @default(uuid())

  userId String @unique
  serviceType ServiceType
  category Category?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldStaff User[] @relation("ServiceManagerStaff")

  assignedServiceRequests ServiceRequest[] @relation("ServiceRequestAssignedServiceManager")

  @@unique([serviceType])
  @@unique([category])
  @@index([serviceType])
  @@index([category])
}

model ComplaintManager {
  id String @id @default(uuid())

  userId String @unique
  complaintType ComplaintType
  category Category?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  investigators User[] @relation("ComplaintManagerInvestigators")

  assignedComplaints Complaint[] @relation("ComplaintAssignedComplaintManager")

  @@unique([complaintType])
  @@index([category])
  @@index([complaintType])
}

model ImportBatch {
  id String @id @default(uuid())
  importedById String
  fileName String
  totalCount Int
  importedCount Int
  skippedCount Int
  failedCount Int
  errors Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importedBy User @relation("ImportBatches", fields: [importedById], references: [id], onDelete: Cascade)

  @@index([importedById, createdAt])
}

model RefreshToken {
  id String @id @default(uuid())

  userId String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

model PasswordResetToken {
  id String @id @default(uuid())

  userId String
  tokenHash String
  expiresAt DateTime
  usedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([tokenHash])
}

model Complaint {
  id          String          @id @default(uuid())
  title       String
  description String          @db.Text
  status      ComplaintStatus @default(SUBMITTED)
  grievanceStatus GrievanceStatus @default(PHASE_1)
  priority    Priority        @default(MEDIUM)
  complaintType ComplaintType    @default(GENERAL_SERVICE)
  category Category?

  createdById  String
  assignedToId String?
  assignedComplaintManagerId String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  canReopenUntil DateTime?
  isReopened Boolean @default(false)
  reopenedAt DateTime?

  createdBy  User  @relation("ComplaintCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo User? @relation("ComplaintAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedComplaintManager ComplaintManager? @relation("ComplaintAssignedComplaintManager", fields: [assignedComplaintManagerId], references: [id], onDelete: SetNull)
  attachments ComplaintAttachment[]

  misuseReports MisuseReport[]
  activityLogs  ActivityLog[]

  @@index([createdById, status, createdAt])
  @@index([assignedToId, status])
  @@index([complaintType, status, createdAt])
  @@index([assignedComplaintManagerId, status])
  @@index([category, status, createdAt])
}

model ComplaintAttachment {
  id String @id @default(uuid())

  complaintId String
  url         String
  publicId    String?
  width       Int?
  height      Int?
  format      String?
  bytes       Int?

  createdAt DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, createdAt])
}

model ServiceRequest {
  id          String               @id @default(uuid())
  title       String
  description String               @db.Text
  type        RequestType?
  category    Category?
  status      ServiceRequestStatus @default(SUBMITTED)
  priority    Priority             @default(MEDIUM)
  isDuplicate Boolean              @default(false)
  duplicateScore Float             @default(0)
  serviceType ServiceType @default(UTILITIES)

  createdById  String
  assignedToId String?
  assignedServiceManagerId String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  completedAt DateTime?
  canReopenUntil DateTime?
  isReopened Boolean @default(false)
  reopenedAt DateTime?

  createdBy  User  @relation("ServiceRequestCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo User? @relation("ServiceRequestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedServiceManager ServiceManager? @relation("ServiceRequestAssignedServiceManager", fields: [assignedServiceManagerId], references: [id], onDelete: SetNull)

  misuseReports MisuseReport[]
  activityLogs  ActivityLog[]
  materialRequests MaterialRequest[]

  @@index([createdById, status, createdAt])
  @@index([assignedToId, status])
  @@index([serviceType, status, createdAt])
  @@index([assignedServiceManagerId, status])
  @@index([category, status, createdAt])
}

model MaterialRequest {
  id String @id @default(uuid())

  serviceRequestId String
  requesterId String
  managerId String

  note String @db.Text
  status String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  requester User @relation("MaterialRequestRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  manager User @relation("MaterialRequestManager", fields: [managerId], references: [id], onDelete: Restrict)

  @@index([serviceRequestId, status, createdAt])
  @@index([requesterId, createdAt])
  @@index([managerId, status, createdAt])
}

model MisuseReport {
  id String @id @default(uuid())

  reporterId     String
  reportedUserId String
  reviewedById   String?

  complaintId      String?
  serviceRequestId String?

  reason      MisuseReportReason
  details     String?            @db.Text
  status      MisuseReportStatus @default(OPEN)
  actionTaken ActionTaken        @default(NONE)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  reviewedAt DateTime?

  reporter     User  @relation("MisuseReportReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  reportedUser User  @relation("MisuseReportReportedUser", fields: [reportedUserId], references: [id], onDelete: Restrict)
  reviewedBy   User? @relation("MisuseReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  complaint      Complaint?      @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([reportedUserId, status, createdAt])
  @@index([reporterId, createdAt])
  @@index([complaintId])
  @@index([serviceRequestId])
}

model Notification {
  id     String @id @default(uuid())
  userId String

  type    NotificationType @default(SYSTEM)
  title   String
  message String           @db.Text
  route   String?
  entityType String?
  entityId String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model ActivityLog {
  id String @id @default(uuid())

  actorId          String?
  targetUserId     String?
  complaintId      String?
  serviceRequestId String?

  action      String
  entityType  ActivityEntityType
  entityId    String
  description String?            @db.Text
  metadata    Json?

  createdAt DateTime @default(now())

  actor          User?           @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser     User?           @relation("ActivityTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  complaint      Complaint?      @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([entityType, entityId, createdAt])
}

enum Role {
  STUDENT
  SERVICE_MANAGER
  STAFF
  COMPLAINT_MANAGER
  INVESTIGATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  WARNED
  BANNED
}

enum ServiceType {
  DORMITORY
  CAFETERIA
  ICT
  LIBRARY
  CLASSROOM
  LABORATORY
  UTILITIES
  TRANSPORT
}

enum Category {
  ICT
  DORMITORY
  CAFETERIA
  CLASSROOM
  LIBRARY
  LABORATORY
  UTILITIES
  TRANSPORT
  CLINIC
}

enum RequestType {
  SERVICE
  COMPLAINT
}

enum ComplaintType {
  ACADEMIC
  FOOD_SERVICE
  DISCIPLINE
  GENERAL_SERVICE
  WOMEN_CASE
  HEALTH_CASE
  DISABILITY_CASE
  SPORTS
}

enum ComplaintStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum GrievanceStatus {
  PHASE_1
  PHASE_2
  PHASE_3
}

enum ServiceRequestStatus {
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MisuseReportReason {
  SPAM
  ABUSIVE_LANGUAGE
  FALSE_INFORMATION
  DUPLICATE_SPAM
  OTHER
}

enum MisuseReportStatus {
  OPEN
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum ActionTaken {
  NONE
  WARNING
  TEMP_SUSPENSION
  PERMANENT_BAN
}

enum NotificationType {
  SYSTEM
  COMPLAINT
  SERVICE_REQUEST
  MISUSE_REPORT
}

enum ActivityEntityType {
  USER
  COMPLAINT
  SERVICE_REQUEST
  MISUSE_REPORT
}
